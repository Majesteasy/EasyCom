# EasyCom — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs réelles UNIQUEMENT en local.
# Ne JAMAIS commiter .env sur GitHub.
# Les secrets réels vont dans Make.com, Meta Developer, Notion, ou variables CI privées.

# ─── AMAZON AFFILIÉ ───────────────────────────────────────────
AMAZON_TAG=easycom0ae-21

# ─── MAKE.COM ─────────────────────────────────────────────────
# URL du webhook Make.com à copier dans index.html › ELION_WEBHOOK_URL
MAKE_WEBHOOK_URL=MAKE_WEBHOOK_URL

# ─── TELEGRAM BOT ─────────────────────────────────────────────
# Bot : @EasyComCEObot2_bot
TELEGRAM_BOT_TOKEN=TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=TELEGRAM_CHAT_ID

# ─── INSTAGRAM GRAPH API ──────────────────────────────────────
# Configurer dans Meta Developer → ne jamais exposer côté client
INSTAGRAM_ACCESS_TOKEN=INSTAGRAM_ACCESS_TOKEN
INSTAGRAM_PAGE_ID=INSTAGRAM_PAGE_ID
INSTAGRAM_VERIFY_TOKEN=INSTAGRAM_VERIFY_TOKEN

# ─── NOTION ───────────────────────────────────────────────────
NOTION_API_KEY=NOTION_API_KEY
NOTION_DATABASE_ID=NOTION_DATABASE_ID

# ─── DEERFLOW 2.0 ─────────────────────────────────────────────
DEERFLOW_API_KEY=DEERFLOW_API_KEY
DEERFLOW_WORKFLOW_ID=DEERFLOW_WORKFLOW_ID

# ─── GOOGLE SHEETS (rapports Amazon Associates) ───────────────
GOOGLE_SHEET_ID=GOOGLE_SHEET_ID
